#!/bin/bash
# Install tmux config by symlinking to this repo

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Symlink config
ln -sf "$SCRIPT_DIR/tmux.conf" ~/.tmux.conf

# Symlink scripts to ~/.local/bin/
mkdir -p ~/.local/bin
ln -sf "$SCRIPT_DIR/tmux-goto" ~/.local/bin/tmux-goto
ln -sf "$SCRIPT_DIR/tmux-goto-window" ~/.local/bin/tmux-goto-window
ln -sf "$SCRIPT_DIR/tmux-goto-pane" ~/.local/bin/tmux-goto-pane
ln -sf "$SCRIPT_DIR/tmux-session-list" ~/.local/bin/tmux-session-list

# Symlink plugins to ~/.tmux/plugins/
mkdir -p ~/.tmux
ln -sf "$SCRIPT_DIR/plugins" ~/.tmux/plugins

# Fix pyyaml import (system pyyaml uses 'import yaml', not 'from pyyaml.lib import yaml')
sed -i 's/from pyyaml.lib import yaml/import yaml/' ~/.tmux/plugins/tmux-which-key/plugin/build.py 2>/dev/null || true

echo "Tmux config installed. Run 'tmux source-file ~/.tmux.conf' to apply."