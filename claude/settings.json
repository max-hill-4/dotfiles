{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Bash(*)",
      "Write",
      "Edit",
      "Read",
      "Glob",
      "Grep"
    ],
    "defaultMode": "acceptEdits",
    "skipDangerousModePermissionPrompt": true
  },
  "model": "sonnet[1m]",
  "statusLine": {
    "type": "command",
    "command": "bash /home/eeg/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true
  },
  "voiceEnabled": true,
  "skipDangerousModePermissionPrompt": true
}
