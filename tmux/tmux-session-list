#!/usr/bin/env bash
# List all sessions for the status bar, highlighting the active one
current=$(tmux display-message -p '#S')
tmux list-sessions -F '#{session_name}' 2>/dev/null | while read -r name; do
    if [ "$name" = "$current" ]; then
        printf '#[fg=#1a1b26,bg=#7aa2f7,bold] %s #[default]' "$name"
    else
        printf '#[fg=#565f89] %s #[default]' "$name"
    fi
done