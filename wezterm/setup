#!/bin/bash
# Install WezTerm config by symlinking to this repo
# WezTerm on Windows reads from %USERPROFILE%\.wezterm.lua

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
WIN_USERPROFILE="/mnt/c/Users/$(whoami)"

# Try to detect actual Windows username if different from Linux username
if [ -f "$WIN_USERPROFILE/.wezterm.lua" ] || [ -d "$WIN_USERPROFILE" ]; then
  :
else
  # Fallback: try common username
  WIN_USERPROFILE="/mnt/c/Users/maxwe"
fi

echo "Symlinking WezTerm config..."
ln -sf "$SCRIPT_DIR/wezterm.lua" "$WIN_USERPROFILE/.wezterm.lua"
echo "WezTerm config installed. Reload with Ctrl+Shift+R in WezTerm."